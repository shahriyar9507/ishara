# Ishara — environment variables (copy to .env.local in web/ and fill in)

# Gemini API key — used server-side only for the sentence-builder (words -> Bangla sentence).
# Get a free key: https://ai.google.dev  (Flash-Lite, free tier ~1500 requests/day)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Cloud TTS (upgrade voice). Leave blank to use free Web Speech API.
# GOOGLE_CLOUD_TTS_KEY=
